        "jsonBody": "={{ {\n  \"model\": \"llama-3.1-8b-instant\",\n  \"temperature\": 0.6,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an elite, first-principles business engineer. Your job is to translate a VALIDATED business opportunity into a concrete, execution-ready acquisition system. Output ONLY valid JSON.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Build a high-velocity acquisition funnel for the following validated offer.\\n\\nINPUT DATA:\\nOffer: \" + $json.body.selected_offer.offer + \"\\nICP: \" + $json.body.selected_offer.ICP + \"\\nPromise: \" + $json.body.selected_offer.promise + \"\\nPricing: \" + $json.body.selected_offer.pricing + \"\\nGuarantee: \" + $json.body.selected_offer.guarantee + \"\\nValidation Score: \" + $json.body.validation_context.score + \"\\nValidation Reason: \" + $json.body.validation_context.reason + \"\\n\\nSTRICT OUTPUT FORMAT (JSON ONLY):\\n{\\n  \\\"funnel\\\": {\\n    \\\"hook\\\": \\\"Short angle\\\",\\n    \\\"landing_page\\\": { \\\"headline\\\": \\\"\\\", \\\"subheadline\\\": \\\"\\\", \\\"cta\\\": \\\"\\\" },\\n    \\\"lead_magnet\\\": \\\"\\\",\\n    \\\"acquisition_channels\\\": [\\\"\\\"],\\n    \\\"conversion_flow\\\": [\\\"\\\"],\\n    \\\"first_7_day_execution\\\": [\\\"\\\" ]\\n  }\\n}\"\n    }\n  ]\n} }}",
        "options": {}
      },
