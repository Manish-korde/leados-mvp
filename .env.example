# ─── LeadOS Environment Variables ─────────────────────────────────────────────

# Groq API (Free LLM - llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_key_here

# HubSpot CRM (Private App Token)
HUBSPOT_PRIVATE_APP_TOKEN=your_hubspot_pat_here

# Calendly (Personal Access Token)
CALENDLY_API_TOKEN=your_calendly_pat_here

# SendGrid (Email API - https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Slack (Incoming Webhook - https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# n8n
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/

# Frontend (Vite - empty for local, full URL for production)
VITE_API_BASE=
